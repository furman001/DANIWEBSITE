{
  "name": "Order",
  "type": "object",
  "properties": {
    "order_number": {
      "type": "string",
      "description": "Auto-generated order number"
    },
    "service_id": {
      "type": "string",
      "description": "Reference to SMMService"
    },
    "service_name": {
      "type": "string",
      "description": "Name of service ordered"
    },
    "platform": {
      "type": "string",
      "description": "Platform name"
    },
    "link": {
      "type": "string",
      "description": "Target URL/link for the service"
    },
    "quantity": {
      "type": "number",
      "description": "Quantity ordered"
    },
    "amount": {
      "type": "number",
      "description": "Total amount in PKR"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "completed",
        "cancelled",
        "partial",
        "failed",
        "admin_review"
      ],
      "default": "pending",
      "description": "Order status"
    },
    "start_count": {
      "type": "number",
      "description": "Start count at time of order"
    },
    "remains": {
      "type": "number",
      "description": "Remaining quantity to deliver"
    },
    "panel_order_id": {
      "type": "string",
      "description": "Order ID returned by the SMM panel API"
    },
    "panel_status": {
      "type": "string",
      "description": "Raw status string returned by the SMM panel API"
    },
    "panel_response": {
      "type": "string",
      "description": "Full JSON response from the SMM panel API (stringified)"
    },
    "panel_submitted_at": {
      "type": "string",
      "description": "ISO timestamp when order was submitted to the panel"
    },
    "panel_error": {
      "type": "string",
      "description": "Error message if the panel API call failed"
    },
    "retry_count": {
      "type": "number",
      "default": 0,
      "description": "Number of times order submission has been retried"
    }
  },
  "required": [
    "service_name",
    "link",
    "quantity",
    "amount"
  ]
}